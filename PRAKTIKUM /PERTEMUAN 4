    "import matplotlib.pyplot as plt\n",
    "\n",
    "def algoritma_dda(x1, y1, x2, y2):\n",
    "    \"\"\"\n",
    "    Algoritma DDA untuk menggambar garis dari (x1,y1) ke (x2,y2)\n",
    "    \"\"\"\n",
    "\n",
    "    dx = x2 - x1\n",
    "    dy = y2 - y1\n",
    "\n",
    "    steps = int(max(abs(dx), abs(dy)))\n",
    "\n",
    "    if steps == 0:\n",
    "        return [x1], [y1]\n",
    "\n",
    "    x_increment = dx / steps\n",
    "    y_increment = dy / steps\n",
    "\n",
    "    x = x1\n",
    "    y = y1\n",
    "\n",
    "    titik_x = []\n",
    "    titik_y = []\n",
    "\n",
    "    for _ in range(steps + 1):\n",
    "        titik_x.append(int(round(x)))\n",
    "        titik_y.append(int(round(y)))\n",
    "        x += x_increment\n",
    "        y += y_increment\n",
    "\n",
    "    return titik_x, titik_y\n",
    "\n",
    "\n",
    "x1, y1 = 2, 3\n",
    "x2, y2 = 10, 8\n",
    "\n",
    "x_points, y_points = algoritma_dda(x1, y1, x2, y2)\n",
    "\n",
    "print(\"ALGORITMA DDA\")\n",
    "print(\"=\" * 40)\n",
    "print(\"Titik-titik yang dihasilkan:\")\n",
    "\n",
    "for x, y in zip(x_points, y_points):\n",
    "    print(f\"({x}, {y})\")\n",
    "\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "\n",
    "plt.plot([x1, x2], [y1, y2], 'r--', alpha=0.5, label='Garis sebenarnya')\n",
    "plt.scatter(x_points, y_points, c='blue', s=80, label='Titik DDA')\n",
    "\n",
    "plt.grid(True)\n",
    "plt.xlabel('X')\n",
    "plt.ylabel('Y')\n",
    "plt.title('Algoritma DDA')\n",
    "plt.legend()\n",
    "plt.axis('equal')\n",
    "\n",
    "plt.show()"
   ]
